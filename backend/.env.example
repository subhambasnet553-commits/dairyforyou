# Copy this file to ".env" and fill in your real values. Never commit ".env" to git.

# Local MongoDB:      mongodb://127.0.0.1:27017/loginSignupDB
# MongoDB Atlas:       mongodb+srv://<user>:<password>@cluster.mongodb.net/loginSignupDB
MONGO_URI=mongodb://127.0.0.1:27017/loginSignupDB

# Any long random string. Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_this_with_a_long_random_secret

# How long login tokens stay valid
JWT_EXPIRES_IN=7d

# Port the server runs on
PORT=5000
